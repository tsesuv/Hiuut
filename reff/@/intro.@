# intro.@
# これでコメント。

>inc 'cslio.@h" # ConSooLe Input/Output . @ language Header

mdl intro # Javaのクラス的なのを採用
{	int main public  ags ag
	{	int demo public <- 32
		# mdl内変数ではpublicを省略時はprivate。

		sys:txoutln 'Hello, world!"
		sys:txoutln demo ~str # ~は型変換演算子

		int demo2 <- 16
		int List[] <- intro:moreFunction demo, demo2
		sys:txoutln List[0]

		int k <- 0, k++, for k < 5
		{	int i <- 0, i++, for i < 10
			{	sys:txoutln 'i: ", i
				sys:txoutln 'k: ", k
			}
		}
		>>?	whileは
			while(a = b)
			{	...
			}
			な標準な感じになるかな
		?<<

		sys:txoutln 2 ^ 3 ~str # = 8

		str s1 <- sys:txin
		s1.fail if # xx:yy.zzやxx.yyはメンバ関数。
		{	sys:txoutln 'Invalid input" # ちなみにsys:txout.noflushやsys:txoutln.noflushにすると
						    # バッファフラッシュをしないでおいておくこともできる。デフォルトは呼び出すとフラッシュされるようになっている。
			trap $D # $なんたらうんたら は見ての通りの16進数。本当は#うんたらかんたらも用意しておきたかったけどコメントで使ってるから仕方なし。
			>>? trapは所謂割り込み。他言語でいう例外処理的な扱いになる。
				まぁ実際はDOS ASMのINT 0x21やINT 0x0Eみたいな割込み命令として使うが標準仕様だけど。
				引数とかはとりあえず未定。トラップ番号ぐらいは入れるつもりではある。
			?<<
		}

		ret 0 # return。

	int moreFunction[] private ags ag
	{	int tmp <- sys:getag ag, 0 # こうなるのかなぁ・・・？わからん。
		int tmp2 <- sys:getag ag, 1 # ただこれならいろいろ便利っちゃ便利ではあるかなぁ。存在しない引数を受け取る可能性はあれど、
									# 呼び出し側でxx:yy ,ag2みたいに書くことでデフォルト引数みたいなこともできないことはないからなぁ

		tmp <- tmp ? tmp2 # <-は代入記号
		tmp2 <- tmp ? tmp2 # ?はXOR演算子
		tmp <- tmp ? tmp2 # ちなみにOR演算子は|、AND演算子は&、NOT演算子は!。
				  # a | bとかa & bとかa ? bとか!aとか、これらはすべて論理式でもありかつ条件式でもある。

		ret [tmp, tmp2]
	}
}

